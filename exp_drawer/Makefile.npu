SDK_ROOT = /home/brkim/mblt-arch-bench/mblt_sdk/qbruntime/qbruntime
INC_DIR  = $(SDK_ROOT)/include
LIB_DIR  = $(SDK_ROOT)/lib

CXX      = g++
CXXFLAGS = -O3 -std=c++17 -Wall -I$(INC_DIR)
LDFLAGS  = -L$(LIB_DIR) -Wl,-rpath,$(LIB_DIR)
LDLIBS   = -lqbruntime -lpthread

TARGETS = npu_bench npu_bench_multi npu_bench_global4 npu_bench_global8 print_mxq_summary

all: $(TARGETS)

%: %.cc
	$(CXX) $(CXXFLAGS) $< -o $@ $(LDFLAGS) $(LDLIBS)

clean:
	rm -f $(TARGETS)

.PHONY: all clean
